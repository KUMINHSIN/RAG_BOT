# Required for Gemini provider
GOOGLE_API_KEY=

# RAG settings
EMBEDDING_PROVIDER=google
LLM_PROVIDER=google
EMBEDDING_MODEL=models/gemini-embedding-001
LLM_MODEL=gemini-2.5-flash

# Data paths
RAW_DOCS_DIR=./data/raw
CHROMA_DIR=./data/chroma
COLLECTION_NAME=thesis_docs

# Retrieval settings
CHUNK_SIZE=1000
CHUNK_OVERLAP=180
RETRIEVAL_K=6

# Query bridge settings (project-specific synonyms)
QUERY_BRIDGE_ENABLED=true
QUERY_BRIDGE_RULES_PATH=./data/query_bridge_rules.json
